<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <object class="AdwNavigationPage" id="taskbar/progressBars">
        <property name="title">Progress Bars</property>
        <property name="child">
            <object class="AdwToolbarView">
                <child type="top">
                    <object class="AdwHeaderBar">
                        <property name="title-widget">
                            <object class="AdwWindowTitle">
                                <property name="title" translatable="yes">Taskbar</property>
                                <property name="subtitle" translatable="yes">Progress Bars</property>
                                <style>
                                    <class name="child-page-title" />
                                </style>
                            </object>
                        </property>
                    </object>
                </child>
                <property name="content">
                    <object class="AdwPreferencesPage" id="taskbar/progressBars-page">
                        <child>
                            <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">General</property>
                                <child>
                                    <object class="AdwComboRow" id="progress-bar-position">
                                        <property name="title" translatable="yes">Position</property>
                                        <property name="model">position-options</property>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child>
                            <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">Layout</property>
                                <child>
                                    <object class="AdwSpinRow" id="progress-bar-width">
                                        <property name="title" translatable="yes">Width</property>
                                        <property name="adjustment">
                                            <object class="GtkAdjustment">
                                                <property name="lower">10</property>
                                                <property name="upper">64</property>
                                                <property name="value">0</property>
                                                <property name="step-increment">1</property>
                                            </object>
                                        </property>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwSpinRow" id="progress-bar-height">
                                        <property name="title" translatable="yes">Height</property>
                                        <property name="adjustment">
                                            <object class="GtkAdjustment">
                                                <property name="lower">1</property>
                                                <property name="upper">20</property>
                                                <property name="value">0</property>
                                                <property name="step-increment">1</property>
                                            </object>
                                        </property>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwSpinRow" id="progress-bar-offset">
                                        <property name="title" translatable="yes">Offset</property>
                                        <property name="adjustment">
                                            <object class="GtkAdjustment">
                                                <property name="lower">0</property>
                                                <property name="upper">30</property>
                                                <property name="value">0</property>
                                                <property name="step-increment">1</property>
                                            </object>
                                        </property>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child>
                            <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">Colors</property>
                                <child>
                                    <object class="AdwActionRow">
                                        <property name="title" translatable="yes">Background Color</property>
                                        <property name="activatable-widget">progress-bar-background-color</property>
                                        <child>
                                            <object class="GtkColorDialogButton" id="progress-bar-background-color">
                                                <property name="valign">center</property>
                                                <property name="dialog">color-dialog</property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwActionRow">
                                        <property name="title" translatable="yes">Fill Color</property>
                                        <property name="activatable-widget">progress-bar-fill-color</property>
                                        <child>
                                            <object class="GtkColorDialogButton" id="progress-bar-fill-color">
                                                <property name="valign">center</property>
                                                <property name="dialog">color-dialog</property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </property>
            </object>
        </property>
    </object>
    <object class="GtkColorDialog" id="color-dialog"/>
    <object class="GtkStringList" id="position-options">
        <items>
            <item translatable="yes">Top</item>
            <item translatable="yes">Bottom</item>
        </items>
    </object>
</interface>

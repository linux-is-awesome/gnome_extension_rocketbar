<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <object class="AdwNavigationPage" id="taskbar/notificationBadges">
        <property name="title">Notification Badges</property>
        <property name="child">
            <object class="AdwToolbarView">
                <child type="top">
                    <object class="AdwHeaderBar">
                        <property name="title-widget">
                            <object class="AdwWindowTitle">
                                <property name="title" translatable="yes">Taskbar</property>
                                <property name="subtitle" translatable="yes">Notification Badges</property>
                                <style>
                                    <class name="child-page-title" />
                                </style>
                            </object>
                        </property>
                    </object>
                </child>
                <property name="content">
                    <object class="AdwPreferencesPage" id="taskbar/notificationBadges-page">
                        <child>
                            <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">General</property>
                                <child>
                                    <object class="AdwComboRow" id="notification-badge-position">
                                        <property name="title" translatable="yes">Position</property>
                                        <property name="model">position-options</property>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwSpinRow" id="notification-badge-max-count">
                                        <property name="title" translatable="yes">Max Count To Display</property>
                                        <property name="adjustment">
                                            <object class="GtkAdjustment">
                                                <property name="lower">1</property>
                                                <property name="upper">999</property>
                                                <property name="value">0</property>
                                                <property name="step-increment">1</property>
                                            </object>
                                        </property>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child>
                            <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">Layout</property>
                                <child>
                                    <object class="AdwSpinRow" id="notification-badge-size">
                                        <property name="title" translatable="yes">Size</property>
                                        <property name="adjustment">
                                            <object class="GtkAdjustment">
                                                <property name="lower">8</property>
                                                <property name="upper">64</property>
                                                <property name="value">0</property>
                                                <property name="step-increment">1</property>
                                            </object>
                                        </property>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwSpinRow" id="notification-badge-roundness">
                                        <property name="title" translatable="yes">Roundness</property>
                                        <property name="adjustment">
                                            <object class="GtkAdjustment">
                                                <property name="lower">0</property>
                                                <property name="upper">64</property>
                                                <property name="value">0</property>
                                                <property name="step-increment">1</property>
                                            </object>
                                        </property>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwSpinRow" id="notification-badge-offset">
                                        <property name="title" translatable="yes">Offset</property>
                                        <property name="adjustment">
                                            <object class="GtkAdjustment">
                                                <property name="lower">0</property>
                                                <property name="upper">30</property>
                                                <property name="value">0</property>
                                                <property name="step-increment">1</property>
                                            </object>
                                        </property>
                                    </object>
                                </child>
                            </object>
                        </child>
                        <child>
                            <object class="AdwPreferencesGroup">
                                <property name="title" translatable="yes">Colors</property>
                                <child>
                                    <object class="AdwActionRow">
                                        <property name="title" translatable="yes">Background</property>
                                        <property name="activatable-widget">notification-badge-color</property>
                                        <child>
                                            <object class="GtkColorDialogButton" id="notification-badge-color">
                                                <property name="valign">center</property>
                                                <property name="dialog">color-dialog</property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwActionRow">
                                        <property name="title" translatable="yes">Border</property>
                                        <property name="activatable-widget">notification-badge-border-color</property>
                                        <child>
                                            <object class="GtkColorDialogButton" id="notification-badge-border-color">
                                                <property name="valign">center</property>
                                                <property name="dialog">color-dialog</property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                                <child>
                                    <object class="AdwActionRow">
                                        <property name="title" translatable="yes">Text</property>
                                        <property name="activatable-widget">notification-badge-font-color</property>
                                        <child>
                                            <object class="GtkColorDialogButton" id="notification-badge-font-color">
                                                <property name="valign">center</property>
                                                <property name="dialog">color-dialog</property>
                                            </object>
                                        </child>
                                    </object>
                                </child>
                            </object>
                        </child>
                    </object>
                </property>
            </object>
        </property>
    </object>
    <object class="GtkColorDialog" id="color-dialog"/>
    <object class="GtkStringList" id="position-options">
        <items>
            <item translatable="yes">Top Left</item>
            <item translatable="yes">Top Right</item>
            <item translatable="yes">Bottom Left</item>
            <item translatable="yes">Bottom Right</item>
        </items>
    </object>
</interface>

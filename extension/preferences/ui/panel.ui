<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <object class="AdwPreferencesPage" id="panel">
        <property name="title" translatable="yes">Panel</property>
        <property name="icon-name">media-view-subtitles-symbolic</property>
        <child>
            <object class="AdwPreferencesGroup">
                <property name="title" translatable="yes">General</property>
                <child>
                    <object class="AdwSwitchRow" id="ui/panel">
                        <property name="title" translatable="yes">Enable Customization</property>
                    </object>
                </child>
                <child>
                    <object class="AdwComboRow" id="position">
                        <property name="title" translatable="yes">Position (LS)</property>
                        <property name="model">position-options</property>
                        <property name="sensitive">false</property>
                    </object>
                </child>
            </object>
        </child>
        <child>
            <object class="AdwPreferencesGroup" id="actions">
                <property name="title" translatable="yes">Actions</property>
                <property name="sensitive">false</property>
                <child>
                    <object class="AdwSwitchRow" id="sound-volume-control">
                        <property name="title" translatable="yes">Sound Volume Control (LS)</property>
                        <property name="subtitle" translatable="yes">Scroll to change the output sound volume, middle button click to toggle mute. Hold down the Ctrl key to slow down the volume change</property>
                    </object>
                </child>
                <child>
                    <object class="AdwSwitchRow" id="click-to-hide-overview">
                        <property name="title" translatable="yes">Click To Hide Overview</property>
                        <property name="subtitle" translatable="yes">When in Overview, left button click on the panel hides the Overview</property>
                    </object>
                </child>
            </object>
        </child>
        <child>
            <object class="AdwPreferencesGroup" id="layout">
                <property name="title" translatable="yes">Layout</property>
                <property name="sensitive">false</property>
                <child>
                    <object class="AdwExpanderRow" id="height-adjustment">
                        <property name="title" translatable="yes">Height Adjustment (LS)</property>
                        <property name="show-enable-switch">true</property>
                        <property name="enable-expansion">false</property>
                        <property name="expanded">false</property>
                        <child>
                            <object class="AdwSpinRow" id="height">
                                <property name="title" translatable="yes">Height</property>
                                <property name="adjustment">
                                    <object class="GtkAdjustment">
                                        <property name="lower">20</property>
                                        <property name="upper">64</property>
                                        <property name="value">0</property>
                                        <property name="step-increment">1</property>
                                    </object>
                                </property>
                            </object>
                        </child>
                    </object>
                </child>
                <child>
                    <object class="AdwExpanderRow" id="transparency">
                        <property name="title" translatable="yes">Transparency</property>
                        <property name="show-enable-switch">true</property>
                        <property name="enable-expansion">false</property>
                        <property name="expanded">false</property>
                        <child>
                            <object class="AdwSwitchRow" id="dynamic-transparency">
                                <property name="title" translatable="yes">Affected By Maximized Windows</property>
                                <property name="subtitle" translatable="yes">Disable transparency when any window is maximized on the same monitor</property>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>
        <child>
            <object class="AdwPreferencesGroup" id="ui/taskbar">
                <property name="title" translatable="yes">Taskbar</property>
                <property name="sensitive">false</property>
                <child type="header-suffix">
                    <object class="GtkSwitch" id="ui/taskbar-state">
                        <property name="valign">center</property>
                    </object>
                </child>
                <child>
                    <object class="AdwComboRow" id="ui/taskbar-alignment">
                        <property name="title" translatable="yes">Alignment</property>
                        <property name="model">alignment-options</property>
                        <property name="visible">false</property>
                    </object>
                </child>
                <child>
                    <object class="AdwSpinRow" id="ui/taskbar-position">
                        <property name="title" translatable="yes">Position</property>
                        <property name="visible">false</property>
                        <property name="adjustment">
                            <object class="GtkAdjustment">
                                <property name="lower">-1</property>
                                <property name="upper">20</property>
                                <property name="value">0</property>
                                <property name="step-increment">1</property>
                            </object>
                        </property>
                    </object>
                </child>
                <child>
                    <object class="AdwActionRow" id="ui/taskbar-customize">
                        <property name="title" translatable="yes">Customize</property>
                        <property name="sensitive">false</property>
                        <property name="activatable">true</property>
                        <child>
                            <object class="GtkImage">
                                <property name="icon-name">go-next-symbolic</property>
                                <property name="accessible-role">presentation</property>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>
        <child>
            <object class="AdwPreferencesGroup" id="ui/notificationCounter">
                <property name="title" translatable="yes">Notification Counter</property>
                <property name="sensitive">false</property>
                <child type="header-suffix">
                    <object class="GtkSwitch" id="ui/notificationCounter-state">
                        <property name="valign">center</property>
                    </object>
                </child>
                <child>
                    <object class="AdwActionRow" id="ui/notificationCounter-customize">
                        <property name="title" translatable="yes">Customize</property>
                        <property name="sensitive">false</property>
                        <property name="activatable">true</property>
                        <child>
                            <object class="GtkImage">
                                <property name="icon-name">go-next-symbolic</property>
                                <property name="accessible-role">presentation</property>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>
    </object>
    <object class="GtkStringList" id="position-options">
        <items>
            <item translatable="yes">Top</item>
            <item translatable="yes">Bottom</item>
        </items>
    </object>
    <object class="GtkStringList" id="alignment-options">
        <items>
            <item translatable="yes">Left</item>
            <item translatable="yes">Center</item>
            <item translatable="yes">Right</item>
        </items>
    </object>
</interface>

<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
    <schema id="org.gnome.shell.extensions.rocketbar2.notification-counter"
            path="/org/gnome/shell/extensions/rocketbar2/notification-counter/">
        <key type="b" name="hide-when-empty">
            <default>false</default>
        </key>
        <key type="b" name="center-clock-position">
            <default>false</default>
        </key>
        <key type="i" name="max-count">
            <default>9</default>
        </key>
        <key type="i" name="font-size">
            <default>10</default>
        </key>
        <key type="i" name="roundness">
            <default>10</default>
        </key>
        <key type="i" name="vertical-offset">
            <default>0</default>
        </key>
        <key type="s" name="color-when-empty">
            <default>'rgb(255, 255, 255)'</default>
        </key>
        <key type="s" name="color-when-not-empty">
            <default>'rgb(255, 255, 255)'</default>
        </key>
        <key type="s" name="text-color">
            <default>'rgb(0, 0, 0)'</default>
        </key>
        <key type="s" name="color-when-empty-dnd">
            <default>'rgba(255, 255, 255, 0.8)'</default>
        </key>
        <key type="s" name="color-when-not-empty-dnd">
            <default>'rgba(255, 255, 255, 0.8)'</default>
        </key>
        <key type="s" name="text-color-dnd">
            <default>'rgb(0, 0, 0)'</default>
        </key>
        <key type="b" name="colors-dnd">
            <default>false</default>
        </key>
    </schema>
</schemalist>

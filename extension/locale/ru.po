msgid "Click Actions"
msgstr "Действия по клику"

#: preferences/ui/tweaks.ui:24
msgid ""
"Left button click on an empty space hides the Overview, long press or right "
"button click toggles the App Grid. Close windows using middle button (or "
"left button while holding down the Ctrl key)"
msgstr ""
"Щелчок левой кнопкой по пустому месту скрывает обзор, долгое нажатие или "
"правая кнопка переключает меню приложений. Закрытие окон средней кнопкой "
"(или левой при удержании Ctrl)"

#: preferences/ui/tweaks.ui:31
msgid "Popups"
msgstr "Всплывающие окна"

#: preferences/ui/tweaks.ui:34
msgid "Remove Display Delay (LS)"
msgstr "Убрать задержку отображения (LS)"

#: preferences/ui/tweaks.ui:35
